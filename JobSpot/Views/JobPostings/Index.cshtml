@model IEnumerable<JobSpot.Models.JobPosting>
@using JobSpot.Constants

@{
    ViewData["Title"] = "Job Postings";
}

<style>
    .font-thick-bold {
        font-family: 'Segoe UI', 'Arial Black', Arial, sans-serif;
        font-weight: 900 !important;
        letter-spacing: 1px;
    }
    .card-title.font-thick-bold {
        font-size: 1.35rem;
    }
    .card-text.font-thick-bold,
    .list-unstyled.font-thick-bold li,
    .btn.font-thick-bold {
        font-size: 1.05rem;
    }
</style>

<h1 class="text-center my-5 font-thick-bold" style="font-size: 2.5rem; color: #343a40; letter-spacing: 2px;">All Jobs</h1>

<div class="container">
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var jobPosting in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm" id="job-posting-@jobPosting.Id" style="border-radius: 1rem; border: 1px solid #e3e6f0;">
                    <div class="card-body" style="background: #f8f9fc;">
                        <h5 class="card-title text-primary" style="font-weight: 600;">@jobPosting.Title</h5>
                        <p class="card-text" style="color: #5a5c69;">@jobPosting.Description</p>
                        <ul class="list-unstyled mb-3" style="font-size: 0.95rem;">
                            <li><i class="bi bi-building"></i> <strong>Company:</strong> <span style="color: #4e73df;">@jobPosting.Company</span></li>
                            <li><i class="bi bi-geo-alt"></i> <strong>Location:</strong> <span style="color: #36b9cc;">@jobPosting.Location</span></li>
                            <li><i class="bi bi-calendar"></i> <strong>Posted:</strong> <span style="color: #858796;">@jobPosting.PostedDate.ToShortDateString()</span></li>
                        </ul>
                        @if (User.IsInRole(UserRoles.Admin) || User.IsInRole(UserRoles.Employer))
                        {
                            <a asp-action="Edit" asp-route-id="@jobPosting.Id" class="btn btn-sm btn-primary me-2" style="border-radius: 0.5rem;">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <button onclick="deleteJobPosting('@jobPosting.Id')"
                                    class="btn btn-sm btn-danger" style="border-radius: 0.5rem;">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function deleteJobPosting(id) {
            if(confirm("Are you sure you want to delete this job posting?"))
            {
                // url
                // type (delete)
                // success -> visually remove the job posting from the list
                // error -> alert the user/show error message

                $.ajax({
                    url: '@Url.Action("Delete", "JobPostings")/' + id,
                    type: "DELETE",
                    success: function (result) {
                        $("#job-posting-" + id).remove(); // Remove the job posting from the DOM
                        alert("Job posting deleted successfully.");
                        location.reload(); // Reload the page to reflect changes
                    },
                    error: function (err) {
                        alert("Error deleting job posting.");
                    }
                });
            }
        }
    </script>
}


