@model IEnumerable<JobSpot.Models.JobPosting>
@using JobSpot.Constants

@{
    ViewData["Title"] = "Job Postings";
}

<h1 class="text-center m-5">All Jobs</h1>

<div class="list-group">
    @foreach (var jobPosting in Model)
    {
        <div class="list-group-item" id="job-posting-@jobPosting.Id">
            <h3>@jobPosting.Title</h3>
            <p>@jobPosting.Description</p>
            <p><strong>Company:</strong> @jobPosting.Company</p>
            <p><strong>Location:</strong> @jobPosting.Location</p>
            <p><strong>Posted Date:</strong> @jobPosting.PostedDate.ToShortDateString()</p>

            @if (User.IsInRole(UserRoles.Admin) || User.IsInRole(UserRoles.Employer))
            {
                <div>
                    <div onclick="deleteJobPosting('@jobPosting.Id')"
                         class="btn btn-sm btn-danger">
                        Delete
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        function deleteJobPosting(id) {
            if(confirm("Are you sure you want to delete this job posting?"))
            {
                // url
                // url
                // type (delete)
                // success -> visually remove the job posting from the list
                // error -> alert the user/show error message

                $.ajax({
                    url: '@Url.Action("Delete", "JobPostings")/' + id,
                    type: "DELETE",
                    success: function (result) {
                        $("#job-posting-" + id).remove(); // Remove the job posting from the DOM
                        alert("Job posting deleted successfully.");
                        location.reload(); // Reload the page to reflect changes
                    },
                    error: function (err) {
                        alert("Error deleting job posting.");
                    }
                });
            }
        }
    </script>
}

